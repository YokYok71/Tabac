{
  "appId": "com.cavatabac.app",
  "appName": "Ma Cave \u00e0 Tabac",
  "webDir": "www",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0a0a0a",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a0a",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    }
  },
  "ios": {
    "backgroundColor": "#0a0a0a",
    "contentInset": "always",
    "scheme": "CaveTabac",
    "limitsNavigationsToAppBoundDomains": false,
    "allowsLinkPreview": false,
    "scrollEnabled": false
  }
}
